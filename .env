# Environment Configuration for Inventory Management System
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
DB_USER=postgres
DB_PASSWORD=yourpassword





# Application Security
SECRET_KEY=your-secret-key-change-this-to-something-random-and-long

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Upload Configuration
UPLOAD_FOLDER=/tmp/uploads
MAX_CONTENT_LENGTH=5242880  # 5MB in bytes

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/inventory/app.log

# Notes:
# - Never commit .env file to version control
# - Use strong passwords in production
# - Generate SECRET_KEY using: python -c "import secrets; print(secrets.token_hex(32))"
# - For production, set FLASK_ENV=production and FLASK_DEBUG=False
